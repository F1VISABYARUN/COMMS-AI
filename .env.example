# Twilio Credentials (find these at https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your purchased Twilio phone number (with country code)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# WhatsApp Sandbox number (default Twilio sandbox)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Your personal mobile number (for outbound call bridging — the phone that rings YOU)
MY_MOBILE_NUMBER=+91XXXXXXXXXX

# Your public URL for Twilio webhooks (use ngrok during development)
# Example: https://abc123.ngrok-free.app
BASE_URL=https://your-ngrok-url.ngrok-free.app
